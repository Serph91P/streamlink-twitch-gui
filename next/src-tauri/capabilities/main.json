{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "main-window",
	"description": "Base permissions for the local main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		{
			"identifier": "opener:allow-open-url",
			"allow": [{ "url": "https://www.twitch.tv/*" }]
		}
	]
}
